{
	"geode": "4.10.0",
	"gd": {
		"win": "2.2074",
		"android": "2.2074",
		"mac": "2.2074",
		"ios": "2.2074"
	},
	"id": "treehousefalcon.auto-download-sounds",
	"name": "Auto Download Sounds",
	"developer": "TreehouseFalcon",
	"version": "v0.1.4",
	"description": "Automatically downloads sound assets for you",
	"tags": [
		"online",
		"enhancement",
		"music",
		"utility"
	],
	"links": {
		"source": "https://github.com/TreehouseFalcon/geode-auto-download-sounds"
	},
	"issues": {
		"info": "Report issues via GitHub Issues",
		"url": "https://github.com/TreehouseFalcon/geode-auto-download-sounds/issues"
	},
	"settings": {
		"download-sounds-when": {
			"name": "Download sounds when",
			"type": "string",
			"one-of": [
				"Level played",
				"Level viewed",
				"Never (Disabled)"
			],
			"default": "Level played"
		},
		"play-when-download-finished": {
			"name": "Play level after sounds download",
			"type": "bool",
			"default": true
		}
	},
	"dependencies": {
		"geode.node-ids": ">=v1.20.0"
	}
}